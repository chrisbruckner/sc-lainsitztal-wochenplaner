# SC Lainsitztal Wochenplaner - Environment Configuration
# Kopieren Sie diese Datei zu .env und füllen Sie die Werte aus

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# ÖFB API Configuration (OPTIONAL)
# Wenn Sie die ÖFB API nutzen möchten, füllen Sie diese aus
# Besorgen Sie den API Key vom Österreichischen Fußballbund

# OEFB_API_BASE=https://api.oefb.at/v1
# OEFB_API_KEY=your_api_key_here
# OEFB_CLUB_ID=your_club_id_here

# Webcal URLs (iCalendar feeds)
# Format: https://calendar.google.com/calendar/ical/... or webcal://...
WEBCAL_U7=https://www.fussballoesterreich.at/netzwerk/icalendar/670725461856634215_100092~1928477580886390934-T.ics
WEBCAL_U8=https://www.fussballoesterreich.at/netzwerk/icalendar/670725461856634215_100092~1928477958843513747-T.ics
